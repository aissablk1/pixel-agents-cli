{
  "name": "pixel-agents-cli",
  "version": "0.1.0",
  "description": "Terminal-native pixel art visualization of Claude Code agents",
  "type": "module",
  "bin": {
    "pixel-agents": "./dist/bin/pixel-agents.js"
  },
  "main": "./dist/src/index.js",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "npm run check-types && node --import tsx esbuild.config.ts",
    "check-types": "tsc --noEmit",
    "dev": "tsx bin/pixel-agents.ts",
    "start": "node dist/bin/pixel-agents.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pngjs": "^7.0.0",
    "ansi-escapes": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.24.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "keywords": [
    "claude-code",
    "pixel-art",
    "terminal",
    "cli",
    "agent-visualization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aissablk1/pixel-agents-cli"
  }
}
